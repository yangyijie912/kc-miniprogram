<!--index.wxml-->
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="page">
    <view wx-if="{{!isSearchResultMode}}" class="toolbar">
      <input
        value="{{ inputKeyword }}"
        bindinput="onSearchInput"
        class="search-input"
        placeholder="搜索问题或答案"
        placeholder-class="placeholder"
      />
      <view class="filter-btn" bindtap="searchCard">筛选</view>
    </view>

    <view wx-if="{{isSearchResultMode}}" class="result-banner">
      <view class="result-title">搜索结果</view>
      <view class="result-keyword">关键词：{{ queryParams.keyword }}</view>
    </view>

    <view wx-if="{{!isSearchResultMode}}" class="filter-row">
      <view class="filter-status">
        <view
          wx-for="{{statusTabs}}"
          wx:key="{{item.value}}"
          class="filter-chip {{ queryParams.status === item.value ? 'active' : '' }}"
          bindtap="toggleStatusFilter"
          data-value="{{ item.value }}"
          >{{ item.label }}</view
        >
      </view>

      <view class="page-actions">
        <view wx-if="{{showQuizAction}}" class="action-tool quiz-btn" bindtap="openQuizSetup">
          <text class="action-tool-icon">▷</text>
        </view>
        <view class="action-tool add-btn" bindtap="goToAddCard">
          <text class="action-tool-icon">+</text>
        </view>
      </view>
    </view>

    <view class="card-list">
      <view wx-for="{{cardViewList}}" wx:key="id" class="card-item" bindtap="goToDetail" data-id="{{ item.id }}">
        <view class="card-top">
          <view class="card-title">
            <view class="card-category">{{ item.categoryName }}</view>
            <view class="card-tag">
              {{ Array.isArray(item.tags) && item.tags.length > 0 ? '/ ' : '' }}
              {{ Array.isArray(item.tags) ? item.tags.join('•') : '' }}
            </view>
          </view>
          <view class="card-status status-{{item.status}}">
            {{ item.statusName ? item.statusName : '新' }}
          </view>
        </view>
        <view class="card-question">{{ item.question }}</view>
        <view class="card-answer">{{ item.answer }}</view>
      </view>

      <view wx-if="{{ cardViewList.length === 0 }}" class="result-banner">
        <view class="result-title">没有找到相关卡片</view>
        <view class="result-keyword">试试调整搜索关键词或筛选条件？</view>
      </view>
    </view>

    <!-- <QuizSetupSheet
      :open="showQuizSetup"
      :categoryId="queryParams.categoryId"
      @close="closeQuizSetup"
      @start="startQuizWithCurrentUI"
    /> -->
  </view>
</scroll-view>
