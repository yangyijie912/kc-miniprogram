{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["miniprogram-api-typings"],
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "noEmit": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "app.js",
    "package-card/**/*.ts",
    "package-card/**/*.js",
    "pages/**/*.ts",
    "pages/**/*.js",
    "components/**/*.ts",
    "components/**/*.js",
    "utils/**/*.ts",
    "utils/**/*.js",
    "services/**/*.ts",
    "services/**/*.js",
    "constants/**/*.ts",
    "constants/**/*.js",
    "types/**/*.ts",
    "types/**/*.js",
    "typings/**/*.d.ts",
    "view-model/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
