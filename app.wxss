page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #efe5d5;
  box-sizing: border-box;
}
.scrollarea {
  flex: 1;
  overflow-x: hidden;
  overflow-y: hidden;
  background: #efe5d5;
}
.page {
  /* min-height: 100vh; */
  background: #efe5d5;
}

/* -------------以下是Markdown 样式-------------- */

/* 将 Markdown 样式从markdown-content组件中移过来，以避免在组件的 wxss 文件中使用标签选择器。 */
.bullet {
  margin-top: 14rpx;
  color: #6c645a;
  font-size: 26rpx;
  line-height: 1.8;
}

.markdown-body {
  word-break: break-word;
}

.markdown-body h1,
.markdown-body h2,
.markdown-body h3,
.markdown-body h4,
.markdown-body h5,
.markdown-body h6 {
  margin: 36rpx 0 18rpx;
  color: #1e1c18;
  line-height: 1.45;
  font-weight: 700;
}

.markdown-body h1 {
  font-size: 40rpx;
}

.markdown-body h2 {
  font-size: 35rpx;
}

.markdown-body h3 {
  font-size: 31rpx;
}

.markdown-body h4,
.markdown-body h5,
.markdown-body h6 {
  font-size: 28rpx;
}

.markdown-body h1:first-child,
.markdown-body h2:first-child,
.markdown-body h3:first-child,
.markdown-body h4:first-child,
.markdown-body h5:first-child,
.markdown-body h6:first-child,
.markdown-body p:first-child,
.markdown-body pre:first-child,
.markdown-body blockquote:first-child,
.markdown-body ul:first-child,
.markdown-body ol:first-child {
  margin-top: 0;
}

.markdown-body p {
  margin: 18rpx 0;
  color: #5e564d;
}

.markdown-body strong {
  color: #1e1c18;
  font-weight: 700;
}

.markdown-body em {
  color: #725f4e;
}

.markdown-body a {
  color: #1f5eff;
  text-decoration: underline;
  word-break: break-all;
}

.markdown-body ul,
.markdown-body ol {
  margin: 18rpx 0;
  padding-left: 34rpx;
}

.markdown-body li {
  margin: 10rpx 0;
  color: #5e564d;
}

.markdown-body blockquote {
  margin: 22rpx 0;
  padding: 18rpx 22rpx;
  border-left: 8rpx solid rgba(18, 122, 114, 0.28);
  border-radius: 0 18rpx 18rpx 0;
  background: rgba(18, 122, 114, 0.06);
  color: #5d6c69;
}

.markdown-body code {
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(61, 43, 24, 0.08);
  color: #7c3f1c;
  font-size: 24rpx;
  font-family: 'Cascadia Code', 'Fira Code', Consolas, monospace;
}

.markdown-body pre {
  margin: 22rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #2a2420;
  overflow: auto;
}

.markdown-body pre code {
  display: block;
  padding: 0;
  background: transparent;
  color: #f7efe6;
  font-size: 24rpx;
  line-height: 1.8;
  white-space: pre;
}

.markdown-body img {
  display: block;
  width: 100%;
  max-width: 100%;
  margin: 22rpx 0;
  border-radius: 20rpx;
}

.markdown-body hr {
  margin: 28rpx 0;
  border: none;
  border-top: 1rpx solid rgba(61, 43, 24, 0.12);
}

/* -------------以上是Markdown 样式-------------- */
