{
  "name": "knowledge-card",
  "private": true,
  "scripts": {
    "clean": "node -e \"try { require('fs').rmSync('dist', { recursive: true, force: true }); } catch (e) { if (e && e.code !== 'EBUSY') throw e; }\"",
    "build:ts": "tsc -p tsconfig.json",
    "build:assets": "node scripts/copy-static.mjs",
    "rewrite:paths": "node scripts/rewrite-path-aliases.mjs",
    "build": "npm run clean && npm run build:assets && npm run build:ts && npm run rewrite:paths",
    "watch:ts": "tsc -p tsconfig.json -w --preserveWatchOutput",
    "watch:assets": "node scripts/copy-static-watch.mjs",
    "watch:paths": "node scripts/rewrite-path-aliases.mjs --watch",
    "dev": "concurrently \"npm:watch:ts\" \"npm:watch:assets\" \"npm:watch:paths\"",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "chokidar": "^4.0.3",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "miniprogram-api-typings": "^5.1.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0"
  }
}
