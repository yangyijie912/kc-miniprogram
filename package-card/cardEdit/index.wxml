<scroll-view class="scrollarea" scroll-y type="list">
  <view class="page">
    <view class="hero-card">
      <view class="eyebrow">Card Editor</view>
      <view class="title">{{ cardId ? '编辑卡片' : '新增卡片' }}</view>
      <view class="desc">进行题目的编辑，编辑的卡片会保存在本地存储，请及时导出进行备份</view>
    </view>

    <view class="form-card">
      <view class="form-header">
        <view class="form-title">基础信息</view>
        <view class="form-tip">修改基础信息，答案尽量概括，笔记可补充更完整的解释、例子或其他相关内容。</view>
      </view>

      <view class="form-group">
        <view class="form-label">分类</view>
        <picker
          mode="selector"
          range="{{categoryOptions}}"
          range-key="name"
          value="{{formData.categoryIndex}}"
          bindchange="onCategoryChange"
        >
          <view class="picker-input {{!formData.categoryName ? 'picker-placeholder' : ''}}">
            {{ formData.categoryName || '请选择分类' }}
          </view>
        </picker>
      </view>

      <view class="form-group">
        <view class="form-label">问题</view>
        <textarea
          value="{{formData.question}}"
          bindinput="onQuestionInput"
          class="form-textarea form-textarea-title"
          placeholder="可以调动回忆或知识点的提问"
          placeholder-class="input-placeholder"
          maxlength="-1"
          auto-height
        />
      </view>

      <view class="form-group">
        <view class="form-label">答案</view>
        <textarea
          value="{{formData.answer}}"
          bindinput="onAnswerInput"
          class="form-textarea"
          placeholder="先写一个简短、能直接展示的答案"
          placeholder-class="input-placeholder"
          maxlength="10000"
          auto-height
        />
      </view>

      <view class="form-group">
        <view class="form-label">笔记</view>
        <markdown-toolbar modelValue="{{formData.content}}" bind:update="onContentInput" />
      </view>

      <view class="form-group">
        <view class="form-label">标签</view>
        <input
          value="{{formData.tagsText}}"
          bindinput="onTagsInput"
          class="form-input"
          placeholder="用顿号或逗号分隔，中英文均可"
          placeholder-class="input-placeholder"
        />
        <view class="field-tip">尽量使用标签来标记题目的相关知识点、考点、难度等信息，方便后续搜索和复习。</view>
      </view>

      <view wx:if="{{cardId}}" class="danger-card">
        <view>
          <view class="danger-title">危险操作</view>
          <view class="danger-desc">请确认不再需要或已经进行导出备份</view>
        </view>
        <view class="danger-btn" bindtap="removeCard">删除卡片</view>
      </view>

      <view class="form-actions">
        <view class="btn btn-secondary" bindtap="cancel">取消</view>
        <view class="btn btn-primary" bindtap="save">保存</view>
      </view>
    </view>
  </view>
</scroll-view>
