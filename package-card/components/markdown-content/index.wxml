<view class="markdown-body">
  <block wx:for="{{markdownBlocks}}" wx:key="index">
    <view wx:if="{{item.type === 'heading'}}" class="md-heading md-h{{item.level}}">
      <rich-text nodes="{{item.html}}"></rich-text>
    </view>

    <view wx:elif="{{item.type === 'paragraph'}}" class="md-paragraph">
      <rich-text nodes="{{item.html}}"></rich-text>
    </view>

    <view wx:elif="{{item.type === 'list'}}" class="md-list">
      <view
        wx:for="{{item.items}}"
        wx:for-item="listItem"
        wx:for-index="listIndex"
        wx:key="index"
        class="md-list-item"
      >
        <text class="md-list-marker">{{item.ordered ? listIndex + 1 + '.' : '•'}}</text>
        <view class="md-list-content">
          <rich-text nodes="{{listItem.html}}"></rich-text>
        </view>
      </view>
    </view>

    <view wx:elif="{{item.type === 'quote'}}" class="md-quote">
      <rich-text nodes="{{item.html}}"></rich-text>
    </view>

    <view wx:elif="{{item.type === 'divider'}}" class="md-divider"></view>

    <scroll-view wx:elif="{{item.type === 'code'}}" scroll-x class="md-code-scroll">
      <text class="md-code">{{item.text}}</text>
    </scroll-view>

    <scroll-view wx:elif="{{item.type === 'table'}}" scroll-x class="md-table-scroll">
      <view class="md-table-grid">
        <view wx:for="{{item.rows}}" wx:for-item="row" wx:for-index="rowIndex" wx:key="index" class="md-table-row">
          <view
            wx:for="{{row.cells}}"
            wx:for-item="cell"
            wx:for-index="cellIndex"
            wx:key="index"
            class="md-table-cell {{cell.head ? 'md-table-head' : ''}}"
          >
            <rich-text nodes="{{cell.html}}"></rich-text>
          </view>
        </view>
      </view>
    </scroll-view>
  </block>
</view>
