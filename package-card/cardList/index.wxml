<view class="page">
  <scroll-view class="scrollarea page-scroll" scroll-y bindscrolltolower="onReachBottom" lower-threshold="120">
    <view wx-if="{{!isSearchResultMode}}" class="toolbar">
      <input
        value="{{ inputKeyword }}"
        bindinput="onSearchInput"
        class="search-input"
        placeholder="问题/答案/笔记/标签"
        placeholder-class="placeholder"
      />
      <view class="filter-btn" bindtap="searchCard">筛选</view>
    </view>

    <view wx-if="{{isSearchResultMode}}" class="result-banner">
      <view class="result-title">搜索结果</view>
      <view class="result-keyword">关键词：{{ queryParams.keyword }}</view>
    </view>

    <view wx-if="{{!isSearchResultMode}}" class="filter-row">
      <view class="filter-status">
          <view
            wx:for="{{statusTabs}}"
            wx:key="label"
            class="filter-chip {{ item.active ? 'active' : '' }}"
            bindtap="toggleStatusFilter"
            data-value="{{ item.value }}"
          >{{ item.label }}</view>
      </view>

      <picker
        class="sort-picker-wrap"
        range="{{sortOptionLabels}}"
        value="{{selectedSortIndex}}"
        disabled="{{isSortMode}}"
        bindchange="onSortChange"
      >
        <view class="sort-picker {{ isSortMode ? 'is-disabled' : '' }}">{{ selectedSortLabel }}</view>
      </picker>

      <view class="page-actions">
        <view class="page-actions-head">
          <view class="page-actions-title">{{ currentModeTitle }}</view>
          <view class="sort-state-tag {{ (isSortMode || isEditMode) ? 'active' : '' }}">
            {{ currentModeTag }}
          </view>
        </view>
        <view class="page-actions-desc">{{ currentModeDesc }}</view>

        <view class="page-actions-body">
          <view
            class="action-pill action-pill-sort {{ isSortMode ? 'active' : '' }} {{ isSortModeDisabled ? 'disabled' : '' }}"
            bindtap="toggleSortMode"
          >
            <image class="action-pill-icon" src="/assets/actions/drag-sort.svg" mode="aspectFit" />
            <view class="action-pill-label">{{ sortModeActionLabel }}</view>
          </view>
          <view wx-if="{{showQuizAction}}" class="action-pill action-pill-quiz" bindtap="openQuizSetup">
            <image class="action-tool-icon-image" src="/assets/actions/quiz.svg" mode="aspectFit" />
            <view class="action-pill-label">测验</view>
          </view>
          <view class="action-pill action-pill-add" bindtap="goToAddCard">
            <image class="action-tool-icon-image" src="/assets/actions/add.svg" mode="aspectFit" />
            <view class="action-pill-label">新增</view>
          </view>
        </view>
      </view>
    </view>

    <view class="card-list {{ isEditMode ? 'is-editing' : '' }} {{ isSortMode ? 'is-sorting' : '' }}">
      <view
        wx:for="{{cardViewList}}"
        wx:for-item="item"
        wx:for-index="index"
        wx:key="id"
        class="card-item {{ isEditMode ? 'is-editing' : '' }} {{ isSortMode ? 'is-sorting' : '' }} {{ item.isSelected ? 'is-selected' : '' }}"
        bindtap="onCardClick"
        bindlongpress="onEdit"
        data-id="{{ item.id }}"
      >
        <view wx:if="{{isSortMode}}" class="card-sort-actions">
          <view
            class="sort-move-btn {{ item.canMoveUp ? '' : 'disabled' }}"
            catchtap="moveCardUp"
            data-id="{{ item.id }}"
            data-index="{{ index }}"
          >↑</view>
          <view
            class="sort-move-btn {{ item.canMoveDown ? '' : 'disabled' }}"
            catchtap="moveCardDown"
            data-id="{{ item.id }}"
            data-index="{{ index }}"
          >↓</view>
        </view>
        <view
          wx:if="{{isEditMode}}"
          class="card-check {{ item.isSelected ? 'selected' : '' }}"
        >
          <view class="card-check-dot"></view>
        </view>
        <view class="card-top">
          <view class="card-title">
            <view class="card-category">{{ item.categoryName }}</view>
          </view>
          <view class="card-status status-{{ item.status ? item.status : 'undefined' }}">
            {{ item.statusName ? item.statusName : '新' }}
          </view>
        </view>
        <view class="card-question">{{ item.question }}</view>
        <view class="card-answer">{{ item.answerPreview }}</view>
        <view wx:if="{{ item.tagText }}" class="card-tag card-tag-bottom">{{ item.tagText }}</view>
        <view wx:else class="card-empty-tag card-tag-bottom">暂无标签</view>
      </view>

      <view wx:if="{{ cardViewList.length === 0 }}" class="result-banner">
        <view class="result-title">没有找到相关卡片</view>
        <view class="result-keyword">试试调整搜索关键词或筛选条件？</view>
      </view>
    </view>

    <view wx:if="{{ cardViewList.length !== 0 }}" class="list-footer">
      <view wx:if="{{ isLoading }}" class="list-footer-text is-loading">正在加载更多...</view>
      <view wx:elif="{{ !hasMore }}" class="list-footer-text">没有更多了</view>
    </view>

    <view wx:if="{{isEditMode || isSortMode}}" class="bottom-placeholder"> </view>
  </scroll-view>

  <view wx:if="{{isSortMode}}" class="sort-bar">
    <view class="sort-summary">
      <view class="sort-title">排序中</view>
      <view class="sort-desc">已按自定义顺序排序，点击卡片左侧按钮上下移动即可调整顺序</view>
    </view>
    <view class="sort-actions">
      <view class="sort-btn sort-btn-secondary" bindtap="toggleSortMode">退出排序</view>
    </view>
  </view>

  <view wx:if="{{isEditMode}}" class="batch-bar">
    <view class="batch-summary">
      <view class="batch-title">已选 {{ selectedCards.length }} 张</view>
      <view class="batch-desc">长按继续选择，完成后可批量转移分类或删除</view>
    </view>
    <view class="batch-actions">
      <view class="batch-btn batch-btn-secondary" bindtap="exitEditMode">取消</view>
      <view class="batch-btn batch-btn-ghost" bindtap="selectCategory">转移分类</view>
      <view class="batch-btn batch-btn-danger" bindtap="batchDelete">删除</view>
    </view>
  </view>

  <base-dialog
    open="{{categoryDialogVisible}}"
    title="选择分类"
    showFooter="{{false}}"
    bind:close="closeCategoryDialog"
  >
    <view class="category-dialog">
      <view class="category-dialog-tip">请选择要转移到的分类，确认后会批量更新已选卡片。</view>
      <picker
        range="{{categoryOptions}}"
        range-key="name"
        value="{{selectedTransferCategoryIndex}}"
        bindchange="onTransferCategoryChange"
      >
        <view class="transfer-picker {{ !selectedTransferCategoryName ? 'placeholder' : '' }}">
          {{ selectedTransferCategoryName || '请选择分类' }}
        </view>
      </picker>
      <view class="transfer-picker-hint">
        当前选择：{{ selectedTransferCategoryName || '未选择' }}
      </view>
    </view>

    <view class="dialog-footer-default">
      <view class="btn btn-cancel" bindtap="closeCategoryDialog">取消</view>
      <view class="btn btn-confirm" bindtap="confirmTransferCategory">转移分类</view>
    </view>
  </base-dialog>

  <quiz-setup-sheet
    open="{{showQuizSetup}}"
    categoryId="{{queryParams.categoryId || ''}}"
    bind:close="closeQuizSetup"
    bind:start="startQuizWithCurrentUI"
  />
</view>
